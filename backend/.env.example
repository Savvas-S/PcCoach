ANTHROPIC_API_KEY=your_anthropic_api_key_here
# Password in this URL must match POSTGRES_PASSWORD set in your shell environment
DATABASE_URL=postgresql+asyncpg://pccoach:change_me@db:5432/pccoach
CLAUDE_MODEL=claude-sonnet-4-6
CORS_ORIGINS=["http://localhost:3000"]
ENVIRONMENT=development
# Rate limits (slowapi format: "N/period" — second, minute, hour, day)
# POST /api/v1/build and POST /api/v1/search share this pool
RATE_LIMIT_AI=2/hour
# GET /api/v1/build/{id}
RATE_LIMIT_READ=60/minute
