FROM python:3.12-slim

COPY --from=ghcr.io/astral-sh/uv:0.5.18 /uv /usr/local/bin/uv

WORKDIR /app

ENV UV_SYSTEM_PYTHON=1

# Install all deps including dev (source mounted via volume)
COPY backend/pyproject.toml backend/uv.lock ./
RUN uv sync --frozen --no-install-project

EXPOSE 8000

# Install engine as editable package (source mounted via volume at /app/engine)
CMD ["sh", "-c", "pip install -e /app/engine 2>/dev/null; uv run uvicorn app.main:app --host 0.0.0.0 --port 8000 --reload --no-server-header"]
