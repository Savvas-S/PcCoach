FROM python:3.12-slim

COPY --from=ghcr.io/astral-sh/uv:0.5.18 /uv /usr/local/bin/uv

WORKDIR /app

ENV UV_SYSTEM_PYTHON=1

# Copy engine source so uv can resolve the local path dependency (../engine relative to /app)
COPY engine/ /engine/

# Install all deps including dev (source mounted via volume)
COPY backend/pyproject.toml backend/uv.lock ./
RUN uv sync --frozen --no-install-project

EXPOSE 8000

CMD ["uv", "run", "uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8000", "--reload", "--no-server-header"]
