### Health check
GET http://localhost:8000/health

###
# BUILD RECOMMENDATIONS
###

### Submit a build - mid range gaming, AMD CPU, Nvidia GPU
POST https://thepccoach.com/api/v1/build 
Content-Type: application/json

{
  "goal": "mid_range_gaming",
  "budget_range": "1000_1500",
  "form_factor": "atx",
  "cpu_brand": "amd",
  "gpu_brand": "nvidia",
  "include_peripherals": false,
  "existing_parts": [],
  "notes": "Prefer quiet components"
}

### Submit a build - high end gaming, no preference, with peripherals
POST http://localhost:8000/api/v1/build
Content-Type: application/json

{
  "goal": "high_end_gaming",
  "budget_range": "2000_3000",
  "form_factor": "atx",
  "cpu_brand": "no_preference",
  "gpu_brand": "no_preference",
  "include_peripherals": true,
  "existing_parts": [],
  "notes": null
}

### Submit a build - designer, already has GPU and case
POST http://localhost:8000/api/v1/build
Content-Type: application/json

{
  "goal": "designer",
  "budget_range": "1500_2000",
  "form_factor": "micro_atx",
  "cpu_brand": "intel",
  "gpu_brand": "no_preference",
  "include_peripherals": false,
  "existing_parts": ["case"],
  "notes": "Need lots of RAM for large files"
}

### Get a build by ID
GET http://localhost:8000/api/v1/build/replace-with-real-id

###
# COMPONENT SEARCH
###

### Find a GPU for 1440p gaming
POST http://localhost:8000/api/v1/search
Content-Type: application/json

{
  "category": "gpu",
  "description": "Best GPU for 1440p gaming, prefer NVIDIA",
  "budget_eur": 400
}

### Find a mid-range AMD CPU
POST http://localhost:8000/api/v1/search
Content-Type: application/json

{
  "category": "cpu",
  "description": "AMD gaming CPU, mid-range, good for streaming"
}

### Find a Mini-ITX case
POST http://localhost:8000/api/v1/search
Content-Type: application/json

{
  "category": "case",
  "description": "Compact Mini-ITX case with good airflow",
  "budget_eur": 120
}
